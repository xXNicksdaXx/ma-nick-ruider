@inproceedings{felber_behavioral_2025,
	location = {New York, {NY}, {USA}},
	title = {Behavioral Programming in the Large using Variability Management},
	isbn = {979-8-4007-1441-2},
	url = {https://dl.acm.org/doi/10.1145/3715340.3715443},
	doi = {10.1145/3715340.3715443},
	series = {{VaMoS} '25},
	abstract = {Behavioral Programming is a paradigm that aims to enable incremental development by utilizing scenarios and use cases for actual software development. The overall behavior is formed by the composition of individual threads (b-threads) that run concurrently with each other and use an event-based mechanism to communicate and effect the system’s state. However, with a rising number of threads, it gets progressively harder to comprehend state changes and system architecture, making design decisions more difficult. This holds in particular for context-aware programs, i.e., systems that need to react to contextual changes. In this paper, we propose the idea of employing feature modeling techniques from variability management to achieve an architectural representation of context-aware behavioral programs, enabling us to model the relations between behavioral threads and facilitating techniques from context-aware variability management. We illustrate multiple potential advantages and apply the approach to two examples from literature.},
	pages = {126--130},
	booktitle = {Proceedings of the 19th International Working Conference on Variability Modelling of Software-Intensive Systems},
	publisher = {Association for Computing Machinery},
	author = {Felber, Tom and Götz, Sebastian},
	urldate = {2026-03-24},
	date = {2025-05-28},
	keywords = {{BP}, {TUD}},
	file = {Full Text PDF:C\:\\Users\\nickr\\Zotero\\storage\\CQWPFFK8\\Felber und Götz - 2025 - Behavioral Programming in the Large using Variability Management.pdf:application/pdf},
}

@inproceedings{felber_comprehensible_2025,
	title = {Comprehensible Self-Aware Behavioral Programming},
	url = {https://ieeexplore.ieee.org/abstract/document/11217465},
	doi = {10.1109/ACSOS-C66519.2025.00064},
	abstract = {Behavioral Programming is a paradigm that uses independent threads as the primary building blocks of an application. The execution of these threads is managed by an event system where threads can wait for, request, or block events. The original intent of this paradigm was incremental development, i.e., the ability to easily add new functionality. Additionally, due to its parallel, dynamic nature, this paradigm is well suited to develop self-aware computing systems. An inherent problem of this paradigm is its incomprehensibility which increases with the size of the application. This is because each thread can specify new events. An overview of the developer is lacking. To overcome this problem, we propose to introduce an architecture description language based on contextual feature trees extended with the event system of behavioral programming. We provide an implementation of this language based on the language server protocol of the universal variability language. Our artifact enables and supports developers to create contextual feature trees for behavioral programs and to use the built-in {SMT} solver to reconfigure behavioral programs at runtime. We show how our artifact can be used with three case studies from different domains: a water tank that aims to keep a specified level and temperature, a smart home system, and a surveillance drone swarm.},
	eventtitle = {2025 {IEEE} International Conference on Autonomic Computing and Self-Organizing Systems Companion ({ACSOS}-C)},
	pages = {215--220},
	booktitle = {2025 {IEEE} International Conference on Autonomic Computing and Self-Organizing Systems Companion ({ACSOS}-C)},
	author = {Felber, Tom and Götz, Sebastian},
	urldate = {2026-03-24},
	date = {2025-09},
	keywords = {{BP}, {TUD}, {FMBP}},
	file = {Snapshot:C\:\\Users\\nickr\\Zotero\\storage\\2B5E7XDE\\11217465.html:text/html},
}

